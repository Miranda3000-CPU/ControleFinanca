# Recommended for most uses
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST/DB_NAME?channel_binding=require&sslmode=require

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://DB_USER:DB_PASSWORD@DB_HOST_UNPOOLED/DB_NAME?sslmode=require

# Parameters for constructing your own connection string
PGHOST=DB_HOST
PGHOST_UNPOOLED=DB_HOST_UNPOOLED
PGUSER=DB_USER
PGDATABASE=DB_NAME
PGPASSWORD=DB_PASSWORD

# Parameters for Vercel Postgres Templates
POSTGRES_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST/DB_NAME?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://DB_USER:DB_PASSWORD@DB_HOST_UNPOOLED/DB_NAME?channel_binding=require&sslmode=require
POSTGRES_USER=DB_USER
POSTGRES_HOST=DB_HOST
POSTGRES_PASSWORD=DB_PASSWORD
POSTGRES_DATABASE=DB_NAME
POSTGRES_URL_NO_SSL=postgresql://DB_USER:DB_PASSWORD@DB_HOST/DB_NAME
POSTGRES_PRISMA_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST/DB_NAME?channel_binding=require&connect_timeout=15&sslmode=require

AUTH_SECRET="replace-with-a-long-secure-secret"
ADMIN_USER="admin"
ADMIN_PASSWORD="change-this-to-a-strong-password"
